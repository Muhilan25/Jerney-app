pipeline {
    agent any
    tools{
        nodejs 'nodejs:20.1.0'
    }
    environment {
        SCANNER_HOME = tool'sonarqube-scanner'
        ECR_REPO = "072583797351.dkr.ecr.ap-south-1.amazonaws.com"
        IMAGE_NAME1 = "nodeapp-frontend"
        IMAGE_NAME2 = "nodeapp-backend"
        IMAGE_TAG = "v${BUILD_NUMBER}"
    }
    stages {

        stage("clean ws") {
            steps {
                cleanWs()
            }
        }

        stage("checkout") {
            steps {
                git branch: 'main', url: 'https://github.com/Muhilan25/Jerney-app.git'
            }
        }

        stage("git leaks") {
            steps {
                sh '''
                    gitleaks detect \
                    --source . \
                    --report-format table \
                    --report-path gitleaks-report.txt || true
                '''
            }
        }

        stage("parallel install") {
            parallel {
                stage("npm install frontend") {
                    steps {
                        dir('frontend') {
                            sh 'npm install'
                        }
                    }
                }
                stage("npm install backend") {
                    steps {
                        dir('backend') {
                            sh 'npm install'
                        }
                    }
                }
            }
            
        }

        stage("parallel test") {
            parallel {
                stage("npm test frontend") {
                    steps {
                        dir('frontend') {
                            sh 'npm test || true'
                        }
                    }
                }
                stage("npm test backend") {
                    steps {
                        dir('backend') {
                            sh 'npm test || true'
                        }
                    }
                }
            }
            
        }

        stage("npm audit") {
            parallel {
                stage("frontend audit") {
                    steps {
                        dir("frontend") {
                            sh 'npm audit --json > ../frontend-audit.json || true'
                        }
                    }
                }
                stage("backend audit") {
                    steps {
                        dir("backend") {
                            sh 'npm audit --json > ../backend-audit.json || true'
                        }
                    }
                }
            }
        }

        stage("download trivy template") {
            steps {
                sh '''
                    curl -L \
                    https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl \
                    -o html.tpl
                '''
            }
        }

        stage("trivy scan") {
            steps {
                sh '''
                    trivy fs . \
                    --format template \
                    --template "@html.tpl" \
                    -o trivy-file.html || true
                '''
            }
        }

        stage("sonarqube") {
            steps {
                withSonarQubeEnv('sonar') {
                    sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=jerney \
                        -Dsonar.projectKey=jerney \
                        -Dsonar.sources=.
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                    timeout(time: 1, unit: 'HOURS') {
                    waitForQualityGate abortPipeline: false
                    }
                }
            }

        stage("frontend docker") {
            steps {
                dir("frontend") {
                    withCredentials([aws(accessKeyVariable: 'AWS_ACCESS_KEY_ID', credentialsId: 'aws-cred', secretKeyVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                    sh '''
                       aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 072583797351.dkr.ecr.ap-south-1.amazonaws.com
                        docker build -t ${IMAGE_NAME1} .
                        docker tag ${IMAGE_NAME1}:latest ${ECR_REPO}/${IMAGE_NAME1}:${IMAGE_TAG}
                    '''
                    }
                }
            }
        }
         stage("backend docker") {
            steps {
                dir("backend") {
                    withCredentials([aws(accessKeyVariable: 'AWS_ACCESS_KEY_ID', credentialsId: 'aws-cred', secretKeyVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                    sh '''
                       aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 072583797351.dkr.ecr.ap-south-1.amazonaws.com
                        docker build -t ${IMAGE_NAME2} .
                        docker tag ${IMAGE_NAME2}:latest ${ECR_REPO}/${IMAGE_NAME2}:${IMAGE_TAG}
                    '''
                    }
                }
            }
        }

        stage("trivy image scan") {
            parallel {
                stage("front-image") {
                    steps {
                         sh '''
                            trivy image \
                            --format template \
                            --template "@html.tpl" \
                            -o trivy-image-front.html \
                            ${ECR_REPO}/${IMAGE_NAME1}:${IMAGE_TAG} || true
                        '''
                    }
                }

                stage("back-image") {
                    steps {
                        sh '''
                            trivy image \
                            --format template \
                            --template "@html.tpl" \
                            -o trivy-image-back.html \
                            ${ECR_REPO}/${IMAGE_NAME2}:${IMAGE_TAG} || true
                        '''
                    }
                }
            }
        }

        stage("frontend docker push") {
            steps {
                dir("frontend") {
                    withCredentials([aws(accessKeyVariable: 'AWS_ACCESS_KEY_ID', credentialsId: 'aws-cred', secretKeyVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                    sh '''
                       aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 072583797351.dkr.ecr.ap-south-1.amazonaws.com
                        docker push ${ECR_REPO}/${IMAGE_NAME1}:${IMAGE_TAG}
                    '''
                    }
                }
            }
        }
         stage("backend docker push") {
            steps {
                dir("backend") {
                    withCredentials([aws(accessKeyVariable: 'AWS_ACCESS_KEY_ID', credentialsId: 'aws-cred', secretKeyVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                    sh '''
                       aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 072583797351.dkr.ecr.ap-south-1.amazonaws.com
                        docker push ${ECR_REPO}/${IMAGE_NAME2}:${IMAGE_TAG}
                    '''
                    }
                }
            }
        }

        stage("update k8s") {
            steps {
                sh '''
                    sed -i "s|nodeapp-frontend:.*|nodeapp-frontend:${IMAGE_TAG}|g" k8s/frontend-deployment.yaml
                    sed -i "s|nodeapp-backend:.*|nodeapp-backend:${IMAGE_TAG}|g" k8s/backend-deployment.yaml
                    cat k8s/frontend-deployment.yaml
                    cat k8s/backend-deployment.yaml
                '''
            }
        }

        stage("Push manifest changes") {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'git-cred',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        git config user.name "Muhilan25"
                        git config user.email "muhilanrangaraj99@gmail.com"

                        git add k8s/*.yaml
                        git commit -m "Update images to ${IMAGE_TAG}" || true

                        git push https://${GIT_USER}:${GIT_TOKEN}@github.com/Muhilan25/Jerney-app.git HEAD:main
                    '''
                }
            }
        }
        
    }
    post {
        always {
            archiveArtifacts artifacts: 'gitleaks-report.txt', followSymlinks: false
            archiveArtifacts artifacts: 'frontend-audit.json', followSymlinks: false
            archiveArtifacts artifacts: 'backend-audit.json', followSymlinks: false
            archiveArtifacts artifacts: 'trivy-file.html', followSymlinks: false
            archiveArtifacts artifacts: 'trivy-image-back.html', followSymlinks: false
            archiveArtifacts artifacts: 'trivy-image-front.html', followSymlinks: false
        }
    }
}